{
  "name": "@snapbug/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/snapbug.umd.cjs",
  "module": "./dist/snapbug.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./messages": {
      "types": "./src/messages.ts",
      "import": "./src/messages.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rrweb/record": "^2.0.0-alpha.20",
    "@snapbug/shared": "workspace:*",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
